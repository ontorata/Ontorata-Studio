{
  "name": "ontorata-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Ontorata Studio — operator console for the Ratary memory brain",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
