# Ratary Server base URL (no trailing /api/v1)
# Local dev:
VITE_RATARY_BASE_URL=http://localhost:9876
# Vercel production (set in Project → Environment Variables, then redeploy):
# VITE_RATARY_BASE_URL=https://ratary.ontorata.com

# API key from Ratary bootstrap (Bearer + X-API-Key)
VITE_RATARY_API_KEY=

# Optional workspace scope
# VITE_RATARY_WORKSPACE_ID=

# Ontory end-user assistant link-out (Phase 26F)
# VITE_ONTORY_URL=https://ontorata.com/ontory
