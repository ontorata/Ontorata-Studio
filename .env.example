# Ontorata Studio environment profiles (Phase 19)
# Copy to .env.local and adjust per profile.

# --- Profile selector (local | staging | production) ---
VITE_STUDIO_PROFILE=local

# --- Ratary connection defaults ---
# Local dev:
VITE_RATARY_BASE_URL=http://localhost:9876
# Staging / production (set in Vercel Project → Environment Variables):
# VITE_RATARY_BASE_URL=https://ratary.ontorata.com

# Do NOT set VITE_RATARY_API_KEY in production — users sign in via login or connection wizard.
# Optional for local dev only:
# VITE_RATARY_API_KEY=

# Optional workspace scope
# VITE_RATARY_WORKSPACE_ID=personal-default

# --- OIDC (Phase 04) — omit for legacy API-key mode ---
# Local Keycloak:
# VITE_AUTH_ISSUER=http://localhost:8080/realms/ontorata
# Production:
# VITE_AUTH_ISSUER=https://auth.ontorata.com/realms/ontorata
# VITE_AUTH_CLIENT_ID=studio-spa

# --- Ontory product link-out ---
# VITE_ONTORY_URL=https://ontorata.com/ontory
