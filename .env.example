# Ratary Server base URL (no trailing /api/v1) — default on login form
# Local dev:
VITE_RATARY_BASE_URL=http://localhost:9876
# Vercel production (set in Project → Environment Variables, then redeploy):
# VITE_RATARY_BASE_URL=https://ratary.ontorata.com

# Do NOT set VITE_RATARY_API_KEY in production — users sign in via the login page.
# Optional for local dev only (still requires login unless you paste the same key):
# VITE_RATARY_API_KEY=

# Optional workspace scope (can also set on login advanced options)
# VITE_RATARY_WORKSPACE_ID=

# Ontory end-user assistant link-out (Phase 26F)
# VITE_ONTORY_URL=https://ontorata.com/ontory
